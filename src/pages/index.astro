---
import Layout from '../layouts/Layout.astro';
import SubjectCard from '../components/SubjectCard.astro';
import subjects from '../data/subjects.json';
const siteUrl = 'https://9lectures.pages.dev';
---

<Layout
  title="Physics Class 9 – Free Lectures for Punjab Board | Math, Chemistry & More"
  desc="Free class 9 lectures for Punjab Board 2026. Watch physics class 9, math, chemistry, computer and urdu video lectures online. Full chapter-wise course."
  canonical={siteUrl}
  noHeader={true}
>
  <div class="text-center mb-6 sm:mb-8 pt-4 animate-fade-in-up">
    <h1 class="text-[22px] sm:text-[28px] font-bold leading-tight">Free Class 9 Lectures – Punjab Board</h1>
    <p class="mt-1.5 text-[14px] sm:text-[15px]" style="color: var(--text-secondary);">Physics, Math, Chemistry, Urdu &amp; Computer · Full Course 2026</p>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 sm:gap-4">
    {subjects.map((s, i) => (
      <div class={`animate-fade-in-up animate-delay-${i + 1}`}>
        <SubjectCard id={s.id} title={s.title} emoji={s.emoji} accent={s.accent} />
      </div>
    ))}
  </div>

</Layout>
