<nav id="bottom-nav"
  class="sm:hidden fixed bottom-0 left-0 right-0 z-50"
  style="background: var(--header-bg); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-top: 1px solid var(--border); padding-bottom: env(safe-area-inset-bottom, 0px);"
>
  <div class="flex items-center justify-around h-14 px-2">
    <a
      href="/"
      class="flex items-center justify-center w-11 h-11 rounded-xl active:scale-90 transition-transform duration-150 touch-min min-w-[44px]"
      aria-label="Home"
    >
      <span
        class="text-[24px] font-bold leading-none gradient-brand"
        style="-webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
      >9</span>
    </a>

    <a
      href="/search/"
      class="flex items-center justify-center w-11 h-11 rounded-xl active:scale-90 transition-transform duration-150 touch-min min-w-[44px]"
      aria-label="Search lectures"
      style="color: var(--text-muted);"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
    </a>

    <a
      href="/notes/"
      class="flex items-center justify-center w-11 h-11 rounded-xl active:scale-90 transition-transform duration-150 touch-min min-w-[44px]"
      aria-label="Subject notes"
      style="color: var(--text-muted);"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
    </a>

    <a
      href="/updates/"
      class="flex items-center justify-center w-11 h-11 rounded-xl active:scale-90 transition-transform duration-150 touch-min min-w-[44px]"
      aria-label="Updates"
      style="color: var(--text-muted);"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
    </a>
  </div>
</nav>

<script>
  (function () {
    var currentPath = window.location.pathname;
    document.querySelectorAll('#bottom-nav a[href]').forEach(function(link) {
      var href = link.getAttribute('href');
      if (href === currentPath) {
        link.setAttribute('aria-current', 'page');
      }
    });
  })();
</script>
