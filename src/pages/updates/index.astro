---
import Layout from '../../layouts/Layout.astro';
import { updates } from '../../data/updates';
import { SITE_URL } from '../../lib/constants';

const iconMap = {
  'new-content': '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>',
  'holiday': '<circle cx="12" cy="12" r="5"/><path d="M12 1v2"/><path d="M12 21v2"/><path d="M4.22 4.22l1.42 1.42"/><path d="M18.36 18.36l1.42 1.42"/><path d="M1 12h2"/><path d="M21 12h2"/><path d="M4.22 19.78l1.42-1.42"/><path d="M18.36 5.64l1.42-1.42"/>',
  'date-sheet': '<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/>',
  'result': '<path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>',
};

function formatDate(d) {
  const dt = new Date(d);
  return dt.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<Layout
  title="Updates – Class 9 Hub"
  desc="Latest updates on new lectures, exam schedules, holidays, and results for class 9 Punjab board."
  canonical={`${SITE_URL}/updates/`}
  noHeader={true}
>
  <h1 class="text-[22px] sm:text-[26px] font-bold mb-1 animate-fade-in-up" style="color: var(--text-primary);">Updates</h1>
  <p class="text-[13px] sm:text-[14px] mb-5 animate-fade-in-up" style="color: var(--text-secondary);">Latest news, new lectures, exam dates, and more.</p>

  <div class="space-y-3">
    {[...updates].reverse().map((item) => (
      <a
        href={`/updates/${item.slug}/`}
        class="rounded-xl p-4 sm:p-5 flex items-start gap-4 animate-fade-in-up group block update-card"
        style="background: var(--card-bg); border: 1px solid var(--border); box-shadow: var(--shadow-card);"
      >
        <div
          class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5"
          style="background: var(--accent)15; color: var(--accent, #8cb4ff);"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconMap[item.type] || iconMap['new-content']} />
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-0.5">
            <span class="text-[15px] font-semibold leading-snug group-hover:opacity-80 transition-opacity" style="color: var(--text-primary);">{item.title}</span>
          </div>
          <p class="text-[13px] leading-relaxed" style="color: var(--text-secondary);">{item.description}</p>
          <span class="text-[11px] mt-1.5 block font-mono" style="color: var(--text-muted);">{formatDate(item.date)}</span>
        </div>
        <svg
          class="flex-shrink-0 mt-2 transition-transform group-hover:translate-x-0.5"
          width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
          style="color: var(--text-muted);"
        ><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    ))}
  </div>
</Layout>

<style is:global>
  @media (hover: hover) {
    .update-card:hover {
      scale: 1.01;
      box-shadow: 0 0 20px color-mix(in srgb, var(--accent, #8cb4ff) 20%, transparent), 0 0 40px color-mix(in srgb, var(--accent, #8cb4ff) 8%, transparent) !important;
      border-color: color-mix(in srgb, var(--accent, #8cb4ff) 40%, transparent) !important;
    }
  }
</style>
