---
import subjects from '../data/subjects.json';

export interface Props {
  showPWA?: boolean;
}

const { showPWA } = Astro.props;
---

<footer
  class={`${showPWA ? 'pb-20' : ''}`}
  style="border-top: 1px solid var(--border);"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-10 sm:py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 sm:gap-10 mb-10">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2.5 no-underline mb-3">
          <div
            class="w-9 h-9 rounded-lg flex items-center justify-center font-mono font-semibold text-[18px] text-white leading-none"
            style="background: linear-gradient(135deg, var(--accent, #6366f1), var(--accent2, #a78bfa));"
          >9</div>
          <span class="text-[15px] font-bold tracking-tight" style="color: var(--text-primary);">Class 9 Hub</span>
        </a>
        <p class="text-[14px] leading-relaxed max-w-[260px]" style="color: var(--text-muted);">
          Free video lectures for Punjab Board 9th graders. All 7 subjects, chapter-wise, completely free.
        </p>
      </div>

      <!-- Subjects -->
      <div>
        <h4 class="text-[11px] font-bold uppercase tracking-[0.8px] mb-3" style="color: var(--text-secondary);">Subjects</h4>
        <div class="space-y-1">
          {subjects.map(s => (
            <a href={`/${s.id}/`} class="block text-[14px] py-1 transition-all duration-200 rounded-md px-1 -mx-1" style="color: var(--text-muted);">
              {s.title}
            </a>
          ))}
        </div>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="text-[11px] font-bold uppercase tracking-[0.8px] mb-3" style="color: var(--text-secondary);">Resources</h4>
        <div class="space-y-1">
          <a href="/search/" class="block text-[14px] py-1 transition-all duration-200 rounded-md px-1 -mx-1" style="color: var(--text-muted);">Search Lectures</a>
          <a href="/notes/" class="block text-[14px] py-1 transition-all duration-200 rounded-md px-1 -mx-1" style="color: var(--text-muted);">Subject Notes</a>
          <a href="/updates/" class="block text-[14px] py-1 transition-all duration-200 rounded-md px-1 -mx-1" style="color: var(--text-muted);">Updates</a>
        </div>
      </div>

      <!-- About -->
      <div>
        <h4 class="text-[11px] font-bold uppercase tracking-[0.8px] mb-3" style="color: var(--text-secondary);">About</h4>
        <div class="space-y-1">
          <a href="mailto:zeeshan@example.com" class="block text-[14px] py-1 transition-all duration-200 rounded-md px-1 -mx-1" style="color: var(--text-muted);">Contact</a>
          <a href="/notes/" class="block text-[14px] py-1 transition-all duration-200 rounded-md px-1 -mx-1" style="color: var(--text-muted);">Content Partners</a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
  <div class="flex flex-col sm:flex-row items-center justify-between gap-2 pt-6" style="border-top: 1px solid var(--border);">
    <p class="text-[13px]" style="color: var(--text-dim);" data-lang="footer">Lectures belong to their respective teachers.</p>
    <p class="text-[13px]" style="color: var(--text-dim);">
      <span data-lang="footerMade">Made by Zeeshan Ahmed</span> · © 2026 Class 9 Hub
    </p>
  </div>
</div>

<style is:global>
  footer a:hover {
    color: var(--text-primary) !important;
    background: rgba(255,255,255,.04);
  }
  .dark footer a:hover {
    background: rgba(255,255,255,.06);
  }
</style>
</footer>
