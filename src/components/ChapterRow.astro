---
export interface Props {
  number: number;
  title: string;
  count: number;
  label: string;
  href: string;
  accent?: string;
}

const { number, title, count, label, href, accent = '#8cb4ff' } = Astro.props;
---

<a
  href={href}
  aria-label={title}
  class="flex items-center gap-3 px-4 min-h-[60px] sm:min-h-[68px] rounded-xl border relative active:scale-[0.97] transition-transform duration-150 chapter-card"
  style="--accent: {accent}; background: var(--card-bg); border-color: var(--border); box-shadow: var(--shadow-card);"
>
  <span
    class="flex items-center justify-center w-8 h-8 rounded font-mono text-sm flex-shrink-0"
    style={`background: ${accent}20; color: ${accent};`}
  >
    {number}
  </span>
  <div class="min-w-0 flex-1">
    <div class="font-body text-[17px] sm:text-[18px] font-medium truncate" style="color: var(--color-title);">{title}</div>
    <span class="font-body text-[14px]" style="color: var(--text-secondary);">{count} <span data-lang={label}>{label}</span></span>
  </div>
  <span class="font-mono text-base" style="color: var(--color-muted);">&rarr;</span>
</a>

<style is:global>
  @media (hover: hover) {
    .chapter-card:hover {
      scale: 1.015;
      box-shadow: 0 0 20px color-mix(in srgb, var(--accent, #8cb4ff) 20%, transparent), 0 0 40px color-mix(in srgb, var(--accent, #8cb4ff) 8%, transparent) !important;
      border-color: color-mix(in srgb, var(--accent, #8cb4ff) 40%, transparent) !important;
    }
  }
</style>
