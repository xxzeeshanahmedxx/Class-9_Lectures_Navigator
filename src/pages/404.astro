---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found">
  <div class="flex flex-col items-center justify-center text-center py-20 gap-4">
    <span class="text-5xl font-mono font-bold" style="color: var(--accent, #8cb4ff);">404</span>
    <h1 class="text-xl font-semibold">Page not found</h1>
    <p class="text-sm opacity-60 max-w-xs">This page doesn't exist or has been moved.</p>
    <a href="/" class="mt-4 px-6 py-2 rounded-xl text-sm font-medium transition-opacity hover:opacity-70" style="background: var(--accent, #8cb4ff); color: #070a1a;">Go home</a>
  </div>
</Layout>
