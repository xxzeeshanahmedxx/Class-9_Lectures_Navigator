---
import ThemeToggle from './ThemeToggle.astro';

export interface Props {
  title: string;
  subtitle?: string;
  backUrl?: string;
  accent?: string;
}

const { title, subtitle, backUrl, accent } = Astro.props;
const subjectClass = accent ? '' : '';
---

<header
  class="sticky top-0 z-40"
  style="background: var(--header-bg); backdrop-filter: blur(24px) saturate(1.2); -webkit-backdrop-filter: blur(24px) saturate(1.2); border-bottom: 1px solid var(--border);"
>
  <div class="flex items-center gap-3 px-4 sm:px-6 h-[60px] sm:h-[64px] max-w-5xl mx-auto">
    <!-- Back / Logo -->
    {backUrl ? (
      <a
        href={backUrl}
        class="flex items-center justify-center w-9 h-9 rounded-lg active:opacity-50 flex-shrink-0 transition-colors duration-150"
        style="color: var(--text-muted);"
        aria-label="Back"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5" />
          <path d="M12 19l-7-7 7-7" />
        </svg>
      </a>
    ) : (
      <a href="/" class="flex items-center gap-2.5 flex-shrink-0 no-underline">
        <div
          class="w-9 h-9 rounded-lg flex items-center justify-center font-mono font-semibold text-[18px] text-white leading-none"
          style="background: linear-gradient(135deg, var(--accent, #6366f1), var(--accent2, #a78bfa)); box-shadow: 0 0 20px rgba(99,102,241,.2), inset 0 1px 0 rgba(255,255,255,.12);"
        >9</div>
        <span class="hidden sm:inline text-[15px] font-bold tracking-tight" style="color: var(--text-primary);">
          Class 9 Hub
        </span>
      </a>
    )}

    <!-- Accent vertical divider -->
    {accent && <div class="w-px h-5 flex-shrink-0" style={`background: ${accent}30;`}></div>}

    <!-- Title area -->
    {backUrl && (
      <div class="min-w-0 flex-1">
        <h1 class="text-[16px] sm:text-[18px] font-bold truncate leading-tight tracking-tight" style="color: var(--text-primary);">
          {title}
        </h1>
        {subtitle && (
          <p class="text-[13px] leading-tight truncate" style="color: var(--text-muted);" data-lang="selectChapter">
            {subtitle}
          </p>
        )}
      </div>
    )}

    {!backUrl && <div class="flex-1"></div>}

    <!-- Nav pill (desktop only) -->
    <nav class="hidden sm:flex items-center gap-1 px-1 py-1 rounded-lg" style="background: rgba(255,255,255,.04); border: 1px solid var(--border);">
      <a href="/" class="px-3 py-1.5 rounded-md text-[13px] font-medium transition-all duration-150" style="color: var(--text-muted);">Home</a>
      <a href="/search/" class="px-3 py-1.5 rounded-md text-[13px] font-medium transition-all duration-150" style="color: var(--text-muted);">Search</a>
      <a href="/notes/" class="px-3 py-1.5 rounded-md text-[13px] font-medium transition-all duration-150" style="color: var(--text-muted);">Notes</a>
      <a href="/updates/" class="px-3 py-1.5 rounded-md text-[13px] font-medium transition-all duration-150" style="color: var(--text-muted);">Updates</a>
    </nav>

    <!-- Search (mobile) -->
    <a
      href="/search/"
      class="flex sm:hidden items-center justify-center w-9 h-9 rounded-lg active:opacity-50 flex-shrink-0"
      style="color: var(--text-muted);"
      aria-label="Search lectures"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8" />
        <path d="M21 21l-4.35-4.35" />
      </svg>
    </a>

    <!-- Theme toggle -->
    <ThemeToggle />

    <!-- Lang toggle -->
    <button
      id="lang-toggle"
      class="flex items-center justify-center w-9 h-9 rounded-lg active:opacity-50 flex-shrink-0 text-[11px] font-bold transition-colors duration-150"
      style="color: var(--text-muted);"
      aria-label="Toggle language"
    >EN</button>
  </div>
</header>
