---
import subjects from '../data/subjects.json';

const accentMap = {};
for (const s of subjects) {
  accentMap[s.id] = { title: s.title, accent: s.accent };
}
---

<section class="continue-studying animate-fade-in-up" data-accents={JSON.stringify(accentMap)}>
  <h2 class="text-[17px] sm:text-[19px] font-bold mb-3" style="color: var(--color-title);" data-lang="continueStudying">Continue Studying</h2>
  <div class="flex gap-3 overflow-x-auto no-scrollbar pb-2" id="continue-scroll">
    <div id="continue-skeleton" class="flex gap-3">
      <div class="flex-shrink-0 rounded-xl border overflow-hidden" style="width:176px;height:108px;background:var(--card-bg);border-color:var(--border);"><div class="h-full w-full shimmer-skeleton"></div></div>
      <div class="flex-shrink-0 rounded-xl border overflow-hidden" style="width:176px;height:108px;background:var(--card-bg);border-color:var(--border);"><div class="h-full w-full shimmer-skeleton"></div></div>
      <div class="flex-shrink-0 rounded-xl border overflow-hidden" style="width:176px;height:108px;background:var(--card-bg);border-color:var(--border);"><div class="h-full w-full shimmer-skeleton"></div></div>
    </div>
  </div>
</section>

<script>
import { getRecent } from '../lib/progress.js';

const section = document.querySelector('.continue-studying');
const scroll = document.getElementById('continue-scroll');
const skeleton = document.getElementById('continue-skeleton');
const accentMap = JSON.parse(section.dataset.accents);
const recent = getRecent();

if (recent.length === 0) {
  section.style.display = 'none';
} else {
  skeleton.style.display = 'none';
  const fragment = document.createDocumentFragment();
  for (const item of recent) {
    const info = accentMap[item.subject];
    if (!info) continue;
    const card = document.createElement('a');
    card.href = `/${item.subject}/${item.chapterId}/`;
    card.className =
      'flex-shrink-0 rounded-xl border overflow-hidden active:scale-[0.97] touch-min transition-transform';
    card.style.cssText =
      'width:176px;background:var(--card-bg);border-color:var(--border);--accent:' + info.accent;
    card.setAttribute('aria-label', `Continue studying: ${item.title}`);
    card.innerHTML = `<div class="p-3 flex flex-col gap-1.5"><span class="font-mono text-[11px] font-medium" style="color:${info.accent}">${info.title}</span><span class="font-body text-[13px] leading-snug line-clamp-2" style="color:var(--text-primary)">${item.title}</span></div>`;
    fragment.appendChild(card);
  }
  scroll.appendChild(fragment);
}
</script>

<style is:global>
  .shimmer-skeleton {
    background: linear-gradient(90deg, var(--card-bg) 25%, var(--border) 50%, var(--card-bg) 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s ease-in-out infinite;
    border-radius: inherit;
  }
  @media (hover: hover) {
    #continue-scroll > a:hover {
      scale: 1.02;
      box-shadow: 0 0 20px color-mix(in srgb, var(--accent, #8cb4ff) 20%, transparent), 0 0 40px color-mix(in srgb, var(--accent, #8cb4ff) 8%, transparent) !important;
      border-color: color-mix(in srgb, var(--accent, #8cb4ff) 40%, transparent) !important;
    }
  }
</style>
