---
import subjects from '../data/subjects.json';
import { getData } from '../lib/data.js';

// Build subject info for client-side rendering
const subjectInfo: Record<string, { title: string; accent: string; chapters: number }> = {};
for (const s of subjects) {
  const d = getData(s.id);
  subjectInfo[s.id] = { title: s.title, accent: s.accent, chapters: d.chapters.length };
}
---

<section class="py-10 sm:py-12" style="background: var(--surface); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);" id="continue-section">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="flex items-end justify-between mb-6">
      <div>
        <h2 class="text-[22px] sm:text-[24px] font-bold tracking-tight" style="color: var(--text-primary);" data-lang="continueStudying">Continue Studying</h2>
        <p class="text-[13px] mt-0.5" style="color: var(--text-muted);">Pick up where you left off</p>
      </div>
    </div>

    <!-- Skeleton (hidden when JS loads) -->
    <div class="flex gap-3 overflow-x-auto no-scrollbar pb-2" id="continue-skeleton">
      <div class="flex-shrink-0 rounded-2xl overflow-hidden" style="width:190px;height:110px;background:var(--card-bg);border:1px solid var(--border);"><div class="h-full w-full shimmer-skeleton"></div></div>
      <div class="flex-shrink-0 rounded-2xl overflow-hidden" style="width:190px;height:110px;background:var(--card-bg);border:1px solid var(--border);"><div class="h-full w-full shimmer-skeleton"></div></div>
      <div class="flex-shrink-0 rounded-2xl overflow-hidden" style="width:190px;height:110px;background:var(--card-bg);border:1px solid var(--border);"><div class="h-full w-full shimmer-skeleton"></div></div>
    </div>

    <!-- Real content (populated by JS) -->
    <div class="flex gap-3 overflow-x-auto no-scrollbar pb-2 hidden" id="continue-scroll"></div>

    <!-- Empty state -->
    <div class="hidden text-center py-6" id="continue-empty">
      <p class="text-[14px]" style="color: var(--text-muted);">Start watching a lecture and it'll show up here.</p>
    </div>
  </div>
</section>

<script is:inline define:vars={{ subjectInfo }}>
(function() {
  var RECENT_KEY = 'c9-recent';
  var section = document.getElementById('continue-section');
  var skeleton = document.getElementById('continue-skeleton');
  var scroll = document.getElementById('continue-scroll');
  var empty = document.getElementById('continue-empty');

  var recent = [];
  try { recent = JSON.parse(localStorage.getItem(RECENT_KEY) || '[]'); } catch(e) {}
  recent = recent.slice(0, 6);

  if (recent.length === 0) {
    skeleton.style.display = 'none';
    empty.classList.remove('hidden');
    return;
  }

  skeleton.style.display = 'none';
  scroll.classList.remove('hidden');

  var fragment = document.createDocumentFragment();
  for (var i = 0; i < recent.length; i++) {
    var item = recent[i];
    var info = subjectInfo[item.subject];
    if (!info) continue;

    var card = document.createElement('a');
    card.href = '/' + item.subject + '/' + item.chapterId + '/';
    card.className = 'flex-shrink-0 rounded-2xl overflow-hidden active:scale-[0.97] touch-min transition-all duration-200';
    card.style.cssText = 'width:190px;background:var(--card-bg);border:1px solid var(--border);';
    card.setAttribute('aria-label', 'Continue: ' + item.title);

    card.innerHTML =
      '<div style="position:absolute;top:0;left:0;right:0;height:2px;background:' + info.accent + ';border-radius:14px 14px 0 0;"></div>' +
      '<div class="p-4 relative">' +
        '<div class="text-[12px] font-semibold mb-2" style="color:' + info.accent + ';">' + info.title + '</div>' +
        '<div class="text-[14px] font-semibold leading-snug line-clamp-2" style="color:var(--text-primary);">' + item.title + '</div>' +
      '</div>';

    card.style.position = 'relative';
    fragment.appendChild(card);
  }
  scroll.appendChild(fragment);
})();
</script>
