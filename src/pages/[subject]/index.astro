---
import Layout from '../../layouts/Layout.astro';
import ChapterRow from '../../components/ChapterRow.astro';
import subjects from '../../data/subjects.json';
import mathData from '../../data/math.json';
import physicsData from '../../data/physics.json';
import chemistryData from '../../data/chemistry.json';
import urduData from '../../data/urdu.json';
import computerData from '../../data/computer.json';

const dataMap = {
  math: mathData, physics: physicsData, chemistry: chemistryData,
  urdu: urduData, computer: computerData,
};

export async function getStaticPaths() {
  return subjects.map((s) => ({
    params: { subject: s.id },
    props: { subject: s },
  }));
}

const { subject } = Astro.props;
const data = dataMap[subject.id];
const chapters = data.chapters || [];
const isExercises = data.kind === 'exercises';
const chNames = chapters.map((ch, i) => ch.title || `Chapter ${ch.number || i + 1}`);
const siteUrl = 'https://9lectures.pages.dev';
const pageUrl = siteUrl + '/' + subject.id + '/';

const subjectDesc = `Free ${subject.id} class 9 lectures for Punjab Board 2025 new book. Watch all ${chapters.length} chapters including ${chNames.slice(0, 3).join(', ')}${chNames.length > 3 ? ' and more' : ''}. Complete video course online.`;

const breadcrumbs = [
  { name: 'Home', url: siteUrl + '/' },
  { name: subject.title + ' Class 9', url: pageUrl },
];

const subjLines = {
  math: `Math Class 9 – Free online video lectures for Punjab Board 2025. Complete course covering real numbers, logarithms, sets and functions, factorization, algebra, linear equations, trigonometry, coordinate geometry, logic, graphs, statistics and probability.`,
  physics: `Physics Class 9 – Free online video lectures for Punjab Board 2025. Complete course covering physical quantities and measurement, kinematics, dynamics, turning effect of forces, work energy and power, mechanical and thermal properties of matter, magnetism and nature of science.`,
  chemistry: `Chemistry Class 9 – Free online video lectures for Punjab Board 2025. Complete course covering structure of atom, chemical bonding, formulae and equations, energetics, equilibrium, acids and bases, periodic table, group properties, hydrocarbons and environmental chemistry.`,
  urdu: `Urdu Class 9 – Free online video lectures for Punjab Board 2025. Complete course covering hamd, naat, ikhlaq-e-hasanah, apni madad aap, nazam, ghazal, khatoot, tashreeh, grammar and essays.`,
  computer: `Computer Class 9 – Free online video lectures for Punjab Board 2025. Complete course covering computer systems and logic, troubleshooting and security, computer networks, computational thinking, web development and data science.`,
};
const visibleLine = subjLines[subject.id] || `Free ${subject.title} class 9 lectures for Punjab Board 2025 new book – ${chapters.length} chapters. Watch complete video course online.`;
---

<Layout
  title={`${subject.title} Class 9 – Complete Course | Free Lectures Punjab Board`}
  subtitle="Select a chapter"
  desc={subjectDesc}
  colors={subject}
  backUrl="/"
  canonical={pageUrl}
  breadcrumbs={breadcrumbs}
>
  <p class="mb-5 text-[14px] leading-relaxed" style="color: var(--text-secondary);">{visibleLine}</p>
  <div class="flex flex-col gap-3">
    {chapters.map((ch, i) => {
      const num = ch.number || ch.chapterNumber || i + 1;
      const chTitle = ch.title || 'Chapter ' + num;
      const row = isExercises ? (
        <ChapterRow
          number={num}
          title={chTitle}
          count={(ch.sections || []).length}
          countLabel="sections"
          href={`/${subject.id}/${ch.id}/`}
          colors={{ accent: subject.accent, soft: subject.soft }}
        />
      ) : (
        <ChapterRow
          number={num}
          title={chTitle}
          count={ch.videos ? ch.videos.length : 0}
          countLabel="videos"
          href={`/${subject.id}/${ch.id}/`}
          colors={{ accent: subject.accent, soft: subject.soft }}
        />
      );
      return <div class="animate-fade-in-up" style={`animation-delay: ${i * 50}ms`}>{row}</div>;
    })}
  </div>
</Layout>
